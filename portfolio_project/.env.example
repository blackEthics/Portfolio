# ── Django Core ─────────────────────────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-strong-secret-key-here

# Set to False in production
DEBUG=False

# Space-separated list of allowed hostnames
ALLOWED_HOSTS=yourdomain.com www.yourdomain.com

# ── Database (leave blank to use SQLite) ────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=portfolio_db
DB_USER=portfolio_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-gmail@gmail.com
CONTACT_RECIPIENT_EMAIL=your-gmail@gmail.com

# ── GitHub Integration ───────────────────────────────────────────────────────
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=ghp_your_token_here
GITHUB_CACHE_SECONDS=300
